# Copy to .env and edit. docker-compose reads .env automatically.

# Where the SQLite DB and archive JSON files live (inside the container).
DATA_DIR=/data

# How often to probe each target (seconds).
PROBE_INTERVAL_SEC=30

# Raw probe rows older than this many days get archived to JSON and dropped.
RETENTION_DAYS=7

# Per-probe timeout in seconds. ICMP and TCP both use this.
PROBE_TIMEOUT_SEC=2

# Local timezone for the dashboard heatmap labels.
TZ=America/New_York

# Optional: override the default targets. Comma-separated "name=address" pairs.
# If omitted, defaults are: google=8.8.8.8, cloudflare=1.1.1.1, gateway=auto.
# TARGETS=google=8.8.8.8,cloudflare=1.1.1.1,quad9=9.9.9.9

# Optional: explicit gateway IP (skips auto-detection from /proc/net/route).
# GATEWAY_IP=192.168.1.1
